# Supabase project
# Public URL from Project Settings > API. Used by both server and browser auth helpers.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon/publishable key from Project Settings > API.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only service role key. Never expose this in client code or public deployments.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Storage bucket for uploaded PDFs. The migrations and docs use "papers".
SUPABASE_STORAGE_BUCKET=papers

# LLM mode
# mock: deterministic local demo mode, no API key required.
# remote: OpenAI-compatible hosted provider such as DeepSeek, Qwen, or OpenAI.
# ollama: local Ollama server that exposes an OpenAI-compatible /v1 endpoint.
# auto: remote when a supported API key exists, otherwise mock.
LLM_MODE=mock

# Generic OpenAI-compatible remote provider.
# Use these when you want one provider-neutral configuration.
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# DeepSeek shortcut configuration. If DEEPSEEK_API_KEY is set in auto mode,
# PaperTree defaults to https://api.deepseek.com and deepseek-chat.
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Qwen / DashScope shortcut configuration. If QWEN_API_KEY or DASHSCOPE_API_KEY
# is set in auto mode, PaperTree defaults to qwen-plus.
# QWEN_API_KEY=
# DASHSCOPE_API_KEY=
# QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# QWEN_MODEL=qwen-plus
# DASHSCOPE_MODEL=qwen-plus

# OpenAI shortcut configuration. If OPENAI_API_KEY is set in auto mode,
# PaperTree defaults to https://api.openai.com/v1 and gpt-4o-mini.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# Local Ollama configuration. Used when LLM_MODE=ollama.
# LOCAL_OLLAMA_URL=http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3
# OLLAMA_API_KEY=ollama
